# =============================================================================
# Enterprise Knowledge Assistant - Environment Variables
# Copy this file to .env and fill in all required values
# NEVER commit .env to version control
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ── Security (REQUIRED - generate with: openssl rand -hex 32) ────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=eka_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=enterprise_rag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://eka_user:CHANGE_ME_strong_password@postgres:5432/enterprise_rag
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_password
REDIS_URL=redis://:CHANGE_ME_strong_password@redis:6379/0
REDIS_TTL_DEFAULT=3600

# ── Ollama (Local LLM) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_LLM_MODEL=llama3:8b
DEFAULT_EMBED_MODEL=nomic-embed-text
RERANKER_MODEL=BAAI/bge-reranker-base

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_PATH=/app/storage
MAX_UPLOAD_SIZE_MB=100

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── OAuth (optional) ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# ── Celery Worker ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGE_ME_strong_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_strong_password@redis:6379/2

# ── Flower (Celery monitoring) ────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_strong_password

# ── RAG Settings ──────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.7
HYBRID_SEARCH_ALPHA=0.5

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=20/hour

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
